{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SsmRunCommandForDeploy",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand",
        "ssm:GetCommandInvocation",
        "ssm:ListCommandInvocations",
        "ssm:CancelCommand"
      ],
      "Resource": [
        "arn:aws:ec2:ap-northeast-2:<AWS_ACCOUNT_ID>:instance/i-08968f306a871d2a4",
        "arn:aws:ssm:ap-northeast-2:*:document/AWS-RunShellScript",
        "arn:aws:ssm:ap-northeast-2:<AWS_ACCOUNT_ID>:*"
      ]
    },
    {
      "Sid": "PushDeployImageToEcr",
      "Effect": "Allow",
      "Action": [
        "ecr:GetAuthorizationToken"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ManageDeployRepository",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:CompleteLayerUpload",
        "ecr:CreateRepository",
        "ecr:DescribeRepositories",
        "ecr:InitiateLayerUpload",
        "ecr:PutImage",
        "ecr:UploadLayerPart"
      ],
      "Resource": "arn:aws:ecr:ap-northeast-2:<AWS_ACCOUNT_ID>:repository/integrated-login-app"
    }
  ]
}
