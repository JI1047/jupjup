{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SsmRunCommandForDeploy",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand",
        "ssm:GetCommandInvocation",
        "ssm:ListCommandInvocations",
        "ssm:CancelCommand"
      ],
      "Resource": [
        "arn:aws:ec2:ap-northeast-2:966000660350:instance/i-08968f306a871d2a4",
        "arn:aws:ssm:ap-northeast-2::document/AWS-RunShellScript",
        "arn:aws:ssm:ap-northeast-2:966000660350:*"
      ]
    },
    {
      "Sid": "PushDeployImageToEcr",
      "Effect": "Allow",
      "Action": [
        "ecr:GetAuthorizationToken"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CreateEcrRepositories",
      "Effect": "Allow",
      "Action": [
        "ecr:CreateRepository",
        "ecr:DescribeRepositories"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ManageDeployRepositories",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:BatchGetImage",
        "ecr:CompleteLayerUpload",
        "ecr:GetDownloadUrlForLayer",
        "ecr:InitiateLayerUpload",
        "ecr:PutImage",
        "ecr:UploadLayerPart"
      ],
      "Resource": [
        "arn:aws:ecr:ap-northeast-2:966000660350:repository/integrated-login-app",
        "arn:aws:ecr:ap-northeast-2:966000660350:repository/zzupzzup-chat"
      ]
    }
  ]
}
